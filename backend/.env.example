# PostgreSQL connection — use asyncpg-compatible URL
# Neon: postgresql://user:password@host/dbname?sslmode=require
# Local: postgresql://postgres:password@localhost:5432/resume_analyzer
DATABASE_URL=postgresql://user:password@localhost:5432/resume_analyzer

# Clerk — copy from Clerk dashboard > API Keys
CLERK_SECRET_KEY=sk_test_...
CLERK_JWKS_URL=https://<your-clerk-domain>/.well-known/jwks.json
# Find JWKS URL: Clerk dashboard > API Keys > Advanced > JWKS URL

# OpenAI — copy from platform.openai.com > API keys
OPENAI_API_KEY=sk-...
